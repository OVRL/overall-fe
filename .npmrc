# 워크스페이스 패키지(apps/*, packages/*)마다 의존성 symlink가 필요합니다.
# node-linker=hoisted 만 쓰면 네이티브 앱 루트에 react/nativewind 등이 매달리지 않아 Metro·tsc가 실패합니다.

strict-peer-dependencies=false

# Windows/Android 네이티브 빌드: 모노레포 루트 + OneDrive + 한글 경로 + pnpm peer 접미사로
# node_modules/.pnpm/... 전체 경로가 260자를 넘기 쉬워 Gradle이 prefab_command.bat 실행 시
# CreateProcess error=2(파일 없음)로 실패할 수 있음(react-native-screens CMake/Prefab 단계).
# https://pnpm.io/npmrc#virtual-store-dir-max-length
# https://pnpm.io/npmrc#virtual-store-dir
virtual-store-dir=.pnpm
# 기본 45보다 더 줄이면 Prefab/CMake 경로 여유가 생김(Windows 한글·긴 경로).
virtual-store-dir-max-length=34

# 경로 이동 없이 완화(Windows): 가상 스토어만 ASCII 짧은 경로에 두기.
# 미리 폴더 생성 후, 설치할 때만:
#   PowerShell: $env:pnpm_config_virtual_store_dir='C:/pnpm-vs'; pnpm install
# (저장소 밖 C:\pnpm-vs 에 링크만 두고, 프로젝트 폴더는 그대로 둠.)

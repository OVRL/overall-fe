{
  "expo": {
    "name": "Overall",
    "slug": "Overall",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ovr-log",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.overall.Overall",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.overall.Overall",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "ios": {
            "fonts": [
              "./assets/fonts/Pretendard-Regular.otf",
              "./assets/fonts/Pretendard-Medium.otf",
              "./assets/fonts/Pretendard-SemiBold.otf",
              "./assets/fonts/Pretendard-Bold.otf"
            ]
          },
          "android": {
            "fonts": [
              {
                "fontFamily": "Pretendard",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Pretendard-Regular.otf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Pretendard-Medium.otf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Pretendard-SemiBold.otf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/Pretendard-Bold.otf",
                    "weight": 700
                  }
                ]
              }
            ]
          }
        }
      ],
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ovr-log to use your location."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#131312",
          "dark": {
            "backgroundColor": "#131312"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ovr-log to access your camera to take photos.",
          "microphonePermission": "Allow ovr-log to access your microphone to record video.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "사진을 선택하려면 사진 라이브러리 접근이 필요합니다."
        }
      ],
      [
        "@react-native-seoul/kakao-login",
        {
          "kakaoAppKey": "42531423b6e6bd15d5806708e81c28c6",
          "kotlinVersion": "2.1.20"
        }
      ],
      [
        "@react-native-seoul/naver-login",
        {
          "urlScheme": "ovr-log"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "78f68efa-aa19-4a71-8850-141659221689"
      },
      "webOrigin": "https://ovr-log.com",
      "applovinMax": {
        "sdkKey": "",
        "bannerAdUnitIdIos": "",
        "bannerAdUnitIdAndroid": ""
      },
      "nativeSocialLogin": {
        "kakaoNativeAppKey": "42531423b6e6bd15d5806708e81c28c6",
        "naverConsumerKey": "HbhJjofPRxpTpWwynMuK",
        "naverConsumerSecret": "bGpccE3y84",
        "naverServiceUrlSchemeIOS": "ovr-log",
        "googleIosClientId": "451258070537-bdebj5st7hiv7u78ku5gqk2s00pu0krj.apps.googleusercontent.com",
        "googleAndroidClientId": "451258070537-757me8au90u9i557qg06h1ss85bphhul.apps.googleusercontent.com"
      }
    }
  }
}
